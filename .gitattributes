# Normalize line endings: LF in the repo AND the working tree. Keeps git
# hooks runnable on Windows (a CRLF shebang breaks /bin/sh) and matches Linux CI.
* text=auto eol=lf

# Windows scripts must stay CRLF or cmd.exe can choke on labels/loops.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.mp4  binary
*.wav  binary
*.pdf  binary
