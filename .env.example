# ════════════════════════════════════════════════════════════════════
# MAS Digital Revamped — environment template.
# Copy to `.env` at THIS repo root and fill in. Loaded from the project
# root only — never from a parent directory. `.env` is gitignored.
# ════════════════════════════════════════════════════════════════════

# ── Supabase (reuses the clean project provisioned 2026-06-14) ──────────
# DATABASE_URL = pooled transaction mode (:6543, pgbouncer) — app runtime
# DIRECT_URL   = session mode (:5432) — prisma migrate / DDL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ── Dashboard access control (allowlisted operator emails, comma-sep) ───
DASHBOARD_ALLOWLIST_EMAILS=you@example.com

# ── AI (all Claude calls go through the gateway; key read once there) ───
ANTHROPIC_API_KEY=sk-ant-xxx

# ── PII hashing (conversion tracking) ───────────────────────────────────
PII_HASH_SALT=change-me

# ── Optional services (add only when the porting slice that needs them lands) ──
# GOOGLE_AI_API_KEY=
# OPENAI_API_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
